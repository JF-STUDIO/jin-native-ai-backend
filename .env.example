PORT=8787
PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Local development can run without real R2/RunningHub.
R2_MOCK=true
RUNNINGHUB_MOCK=true

# Cloudflare R2, production/staging
# You can either use the short R2_* names below, or reuse the existing
# website backend names:
# METROVAN_OBJECT_STORAGE_ENDPOINT
# METROVAN_OBJECT_STORAGE_BUCKET
# METROVAN_OBJECT_STORAGE_ACCESS_KEY_ID
# METROVAN_OBJECT_STORAGE_SECRET_ACCESS_KEY
# METROVAN_OBJECT_STORAGE_REGION
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PUBLIC_BASE_URL=
R2_KEY_PREFIX=native-app
R2_UPLOAD_EXPIRES_SECONDS=900
R2_RESULT_EXPIRES_SECONDS=21600

# RunningHub, keep these only on backend
# You can either use the short RUNNINGHUB_* names below, or reuse:
# METROVAN_RUNNINGHUB_API_KEY
# METROVAN_RUNNINGHUB_DEFAULT_WORKFLOW_ID
# METROVAN_RUNNINGHUB_DEFAULT_INSTANCE_TYPE
# METROVAN_RUNNINGHUB_DEFAULT_INPUT_NODE_ID
# METROVAN_RUNNINGHUB_DEFAULT_INPUT_FIELD
# METROVAN_RUNNINGHUB_DEFAULT_INPUT_MODE
RUNNINGHUB_API_KEY=
RUNNINGHUB_WORKFLOW_ID=
RUNNINGHUB_INSTANCE_TYPE=
RUNNINGHUB_INPUT_NODE_ID=
RUNNINGHUB_INPUT_FIELD=
RUNNINGHUB_INPUT_MODE=image
RUNNINGHUB_OUTPUT_NODE_ID=
RUNNINGHUB_OUTPUT_FIELD=output
RUNNINGHUB_OUTPUT_MODE=file
RUNNINGHUB_OUTPUT_POLL_SECONDS=3600

# Apple In-App Purchase validation and credit ledger.
# Use "decode" for local development without real StoreKit JWS certificates.
# Use "strict" for production after testing server-side JWS verification.
APPLE_BUNDLE_ID=com.jin.realestatemarketing
APPLE_IAP_VALIDATION_MODE=decode
DEFAULT_STARTING_CREDITS=0

# Hidden admin console. Use a strong ADMIN_SESSION_SECRET in production.
ADMIN_EMAILS=zhoujin0618@gmail.com
ADMIN_PIN=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=21600
