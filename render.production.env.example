PUBLIC_API_BASE_URL=https://jin-native-ai-backend.onrender.com

R2_MOCK=false
RUNNINGHUB_MOCK=false

R2_BUCKET=<bucket name>
R2_ACCESS_KEY_ID=<access key>
R2_SECRET_ACCESS_KEY=<secret key>
R2_ACCOUNT_ID=<cloudflare account id>
R2_REGION=auto
R2_KEY_PREFIX=native-app
R2_UPLOAD_EXPIRES_SECONDS=900
R2_RESULT_EXPIRES_SECONDS=21600

RUNNINGHUB_API_KEY=<api key>
RUNNINGHUB_WORKFLOW_ID=<workflow id>
RUNNINGHUB_INSTANCE_TYPE=plus
RUNNINGHUB_INPUT_NODE_ID=<input node id>
RUNNINGHUB_INPUT_FIELD=image
RUNNINGHUB_INPUT_MODE=image
RUNNINGHUB_OUTPUT_NODE_ID=<output node id, if needed>
RUNNINGHUB_OUTPUT_FIELD=output
RUNNINGHUB_OUTPUT_MODE=file
RUNNINGHUB_OUTPUT_POLL_SECONDS=3600

APPLE_BUNDLE_ID=com.jin.realestatemarketing
APPLE_IAP_VALIDATION_MODE=strict
DEFAULT_STARTING_CREDITS=0

ADMIN_EMAILS=zhoujin0618@gmail.com
ADMIN_PIN=<admin pin>
ADMIN_SESSION_SECRET=<random 32+ character secret, not the pin>
ADMIN_SESSION_TTL_SECONDS=21600
